{
  "expo": {
    "name": "bree-flowies",
    "slug": "bree-flowies",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "breeflowies",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.sharify.bree-flowies"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "bree flowies uses the camera to shoot photos into your group's event roll.",
          "microphonePermission": "bree flowies uses the microphone to record video clips into your group's event roll."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "bree flowies needs access to your photos so you can set a profile picture.",
          "cameraPermission": "bree flowies uses the camera so you can take a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0A09",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "bree flowies needs access to save photos from your group's roll to your camera roll.",
          "photosPermission": "bree flowies needs access to save photos from your group's roll to your camera roll.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-sharing",
      "expo-video",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
